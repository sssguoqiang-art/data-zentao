# Copy this file to .env and fill in the real values locally.
# Do not commit .env.

ZENTAO_DB_HOST=
ZENTAO_DB_PORT=3306
ZENTAO_DB_USER=
ZENTAO_DB_PASSWORD=
ZENTAO_DB_NAME=zentao

# Optional first-start password gate.
# The default hash enables a shared startup password. Ask the repository owner
# for the password, then unlock this computer once with: data-zentao unlock
# To disable this local gate, clear the value below.
DATA_ZENTAO_START_PASSWORD_SHA256=1e59129a89a5ae71be1f024477f2c82aa808ac247c26ee970579eee89873c8c2

# Optional defaults used by the first built-in reports.
ZENTAO_PLATFORM_PRODUCT_NAME=平台部
ZENTAO_PLATFORM_PROJECT_NAME=平台部
