# Copy this file to .env and fill in the real values locally.
# Do not commit .env.

ZENTAO_DB_HOST=
ZENTAO_DB_PORT=23306
ZENTAO_DB_USER=
ZENTAO_DB_PASSWORD=

# Optional local access-password gate.
# Recommended path: run data-zentao setup and enter Git访问密码 there.
# Manual path: run data-zentao hash-password, paste the generated hash below,
# then unlock this computer once with: data-zentao unlock
DATA_ZENTAO_START_PASSWORD_SHA256=
